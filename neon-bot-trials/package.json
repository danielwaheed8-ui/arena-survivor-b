{
  "name": "neon-bot-trials",
  "version": "1.0.0",
  "private": true,
  "description": "Neon Bot Trials — a physics-based modular robot parkour simulator for the browser.",
  "scripts": {
    "dev": "next dev -p 4310",
    "build": "next build",
    "start": "next start -p 4310",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "visual:qa": "npm run build && playwright test --config=qa/playwright.config.ts; node qa/report.mjs",
    "visual:qa:only": "playwright test --config=qa/playwright.config.ts; node qa/report.mjs"
  },
  "dependencies": {
    "matter-js": "^0.20.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/matter-js": "^0.19.7",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9"
  }
}
